        {
          "type": "text",
          "id": "wdPgu",
          "x": 48,
          "y": 870,
          "name": "Hero Subtitle",
          "fill": "#F7F4EBCC",
          "textGrowth": "fixed-width",
          "width": 400,
          "content": "We are not just one car. We are a unified fleet\nof 4 classic vehicles taking on the ultimate\ndesert challenge. Students bound by mechanics,\nsolidarity, and the Moroccan dunes.",
