        },
        {
          "type": "text",
          "id": "ZHjn4",
          "x": 140,
          "y": 1120,
          "name": "Challenge Title",
          "fill": "$--text-primary",
          "textGrowth": "fixed-width",
          "width": 500,
          "content": "MORE THAN\nA RALLY.\nA RITE OF\nPASSAGE.",
          "lineHeight": 0.92,
          "fontFamily": "Anton",
          "fontSize": 68,
          "fontWeight": "normal",
          "letterSpacing": 2
        },
        {
          "type": "text",
          "id": "XXdUA",
          "x": 140,
          "y": 1420,
          "name": "Challenge Body",
          "opacity": 0.8,
          "fill": "$--text-primary",
          "textGrowth": "fixed-width",
          "width": 460,
          "content": "Uniraid is a solidarity adventure across Morocco for students. The rules are brutal: 20-year-old minimum car age, no GPS, no support vehicles. Just a roadbook, a compass, and a trunk full of charity supplies for desert villages.\n\nMore than a race — it's a test of perseverance, navigation, and human spirit across 6,000 kilometers of unforgiving terrain.",
          "lineHeight": 1.7,
          "fontFamily": "Inter",
          "fontSize": 15,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "rkrC2",
          "x": 140,
          "y": 1680,
          "name": "Chall Coord 1",
          "fill": "$--accent-moss",
          "content": "RULES  ·  NO GPS  ·  NO SUPPORT  ·  20YR+ CARS",
          "fontFamily": "Geist Mono",
          "fontSize": 10,
          "fontWeight": "normal",
          "letterSpacing": 2
        },
