        {
          "type": "text",
          "id": "AijvO",
          "x": 140,
          "y": 1080,
          "name": "Waypoint 01 Tag",
          "fill": "$--accent-rust",
          "content": "[ 01 ]  WHAT IS UNIRAID",
          "fontFamily": "Geist Mono",
          "fontSize": 11,
          "fontWeight": "600",
