---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/svelte/Hero.svelte';
import About from '../components/svelte/About.svelte';
import CarShowcase from '../components/svelte/CarShowcase.svelte';
import Team from '../components/svelte/Team.svelte';
import Gallery from '../components/svelte/Gallery.svelte';
import Sponsors from '../components/svelte/Sponsors.svelte';
import Contact from '../components/svelte/Contact.svelte';
import Footer from '../components/svelte/Footer.svelte';
---

<Layout>
  <Hero client:load />

  <About client:visible />

  <!-- Animated Divider -->
  <div class="mx-auto max-w-7xl px-6">
    <div class="animated-divider"></div>
  </div>

  <CarShowcase client:visible />

  <!-- Animated Divider -->
  <div class="mx-auto max-w-7xl px-6">
    <div class="animated-divider"></div>
  </div>

  <Team client:visible />

  <Gallery client:visible />

  <!-- Animated Divider -->
  <div class="mx-auto max-w-7xl px-6">
    <div class="animated-divider"></div>
  </div>

  <Sponsors client:visible />

  <Contact client:visible />

  <Footer client:load />
</Layout>
